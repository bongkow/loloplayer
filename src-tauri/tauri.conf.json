{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "loloplayer",
  "version": "1.0.4",
  "identifier": "com.skim.loloplayer",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "loloplayer",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "lib/**/*"
    ],
    "externalBin": [
      "ffmpeg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "mp4",
          "mkv",
          "avi",
          "mov",
          "webm",
          "flv",
          "wmv",
          "m4v",
          "3gp",
          "ts"
        ],
        "name": "Video",
        "description": "Video File",
        "role": "Viewer"
      }
    ]
  },
  "plugins": {
    "cli": {
      "description": "Video Player",
      "args": [
        {
          "name": "file",
          "description": "Video file to open",
          "index": 1,
          "takesValue": true
        }
      ]
    }
  }
}
